# Demo / local — copy to .env.local (gitignored). Do NOT commit real keys.
# Vercel: Project → Settings → Environment Variables (Production + Preview).

# OpenCode Zen — Echo Mirage OPENCODE gateway (https://opencode.ai/zen/v1)
OPENCODE_ZEN_API_KEY=

# OpenCode Go — subscription lane (https://opencode.ai/zen/go/v1; gateway not wired yet)
OPENCODE_GO_API_KEY=

# OpenAI direct
OPENAI_API_KEY=

# OpenRouter
OPENROUTER_API_KEY=

# MUTHUR direct Synapse/Pi desktop control (local dev default on; set 0 to disable)
MUTHUR_DIRECT_PI_COMPUTER_USE=1

# Optional public keys for openai/openrouter only (never use NEXT_PUBLIC_* for OpenCode)
# NEXT_PUBLIC_OPENAI_API_KEY=
# NEXT_PUBLIC_OPENROUTER_API_KEY=
