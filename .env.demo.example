# Demo deployment — set these in Vercel → Project → Settings → Environment Variables
# (Production + Preview). Keys stay on the server; visitors never paste a key.
#
# Do NOT commit real keys. Copy this file to .env.local for local demo testing only.

# OpenCode / Zen gateway (either name works; opencode is checked first)
OPENCODE_API_KEY=
ZEN_API_KEY=

# OpenAI direct
OPENAI_API_KEY=

# OpenRouter
OPENROUTER_API_KEY=

# Optional: build-time client keys (NOT recommended for shared demos — exposed in JS bundle)
# NEXT_PUBLIC_OPENCODE_API_KEY=
# NEXT_PUBLIC_ZEN_API_KEY=
# NEXT_PUBLIC_OPENAI_API_KEY=
# NEXT_PUBLIC_OPENROUTER_API_KEY=
