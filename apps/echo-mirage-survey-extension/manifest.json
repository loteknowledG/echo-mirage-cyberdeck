{
  "manifest_version": 3,
  "name": "echo-extension",
  "short_name": "echo-extension",
  "version": "0.2.2",
  "description": "echo-extension — copy Chrome tab text for Survey (HackerRank-aware via echo-electron).",
  "permissions": ["activeTab", "scripting", "storage", "tabs", "alarms"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "echo-extension",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "http://127.0.0.1:*/*",
        "http://localhost:*/*",
        "https://echo-mirage-cyberdeck.vercel.app/*"
      ],
      "js": ["content-mirage.js"],
      "run_at": "document_idle"
    }
  ],
  "externally_connectable": {
    "matches": [
      "http://127.0.0.1:*/*",
      "http://localhost:*/*",
      "https://echo-mirage-cyberdeck.vercel.app/*"
    ]
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
