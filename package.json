  "pnpm": {
    "overrides": {
      "pdfjs-dist": "^6.0.227",
      "parse5": "^7.3.0",
      "pako": "2.1.0"
    },
    "onlyBuiltDependencies": [
      "@google/genai",
      "@mongodb-js/zstd",
      "electron",
      "node-screenshots"
    ]
  },
  "build": {
    "appId": "com.craftwerk.echomirage",
    "productName": "Echo Mirage Cyberdeck",
    "copyright": "Copyright © Craftwerk Corp",
    "protocols": [
      {
        "name": "Echo Mirage Cyberdeck",
        "schemes": [
          "echomirage"
        ]
      }
    ],
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "extraResources": [
      {
        "from": ".next/standalone-electron",
        "to": "app",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico",
      "artifactName": "Echo-Mirage-Cyberdeck-Setup-${version}.${ext}",
      "shortcutName": "Echo Mirage Cyberdeck"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "public/icon-512.png",
      "identity": "-",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "artifactName": "Echo-Mirage-Cyberdeck-${version}.${ext}",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "type": "development",
      "extendInfo": {
        "LSMinimumSystemVersion": "12.0",
        "NSHumanReadableCopyright": "Copyright © Craftwerk Corp"
      }
    },
    "dmg": {
      "title": "Echo Mirage Cyberdeck ${version}",
      "icon": "public/icon-512.png"
    },
    "publish": {
      "provider": "generic",
      "url": "https://github.com/loteknowledG/echo-mirage-cyberdeck/releases/latest/download"
    }
  }
