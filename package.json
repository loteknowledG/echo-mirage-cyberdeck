    "probe:muthur-speech-text": "tsx scripts/probe-muthur-speech-text.ts",
    "probe:muthur-foundation-001": "tsx scripts/probe-muthur-foundation-001.ts",
    "probe:foundation-server-boundary": "tsx scripts/probe-foundation-server-boundary.ts",
    "probe:muthur-document-open": "tsx scripts/probe-muthur-document-open.ts",
    "probe:provider-credentials": "tsx scripts/probe-provider-credentials.ts",
    "probe:workspace-create-folder": "tsx scripts/probe-workspace-create-folder.ts",
    "probe:memory-atlas": "tsx scripts/probe-memory-atlas.ts",
    "probe:entity-atlas": "tsx scripts/probe-entity-atlas.ts",
    "probe:cadre-host": "tsx scripts/probe-cadre-host.ts",
    "probe:cadre-events": "tsx scripts/probe-cadre-events.ts",
    "probe:codex-runtime-adapter": "tsx scripts/probe-codex-runtime-adapter.ts",
    "probe:codex-readiness-detector": "tsx scripts/probe-codex-readiness-detector.ts",
    "probe:photoshop-text-on-gif": "tsx scripts/probe-photoshop-text-on-gif.ts",
    "probe:capability-receipts": "tsx scripts/probe-capability-receipts.ts",
    "discover:continuity-artifacts": "tsx scripts/discover-continuity-artifacts.ts",
    "render:continuity-docs": "tsx scripts/render-continuity-docs.ts",
    "probe:muthur-lineage-discovery": "tsx scripts/probe-muthur-lineage-discovery.ts",
    "probe:muthur-phases": "pnpm probe:muthur-phase-a && pnpm probe:muthur-phase-b && pnpm probe:muthur-phase-c && pnpm probe:muthur-operator-disk-save && pnpm probe:muthur-atlas-memory",
    "probe:muthur-open-operator": "tsx scripts/probe-muthur-open-operator.ts",
    "probe:powerfist-muthur-tools": "tsx scripts/probe-powerfist-muthur-tools.ts",
    "probe:property-manager-call-persistence": "tsx scripts/probe-property-manager-call-persistence.ts",
    "probe:property-manager-case-viewer": "tsx scripts/probe-property-manager-case-viewer.ts",
    "probe:property-manager-case-actions": "tsx scripts/probe-property-manager-case-actions.ts",
    "probe:muthur-dsml": "tsx scripts/probe-dsml-parse.ts",
    "probe:operator-file-surface": "tsx scripts/probe-operator-file-surface.ts",
    "probe:resolve-convert-document-path": "tsx scripts/probe-resolve-convert-document-path.ts",
    "puppeteer:install": "node scripts/install-puppeteer-chrome.mjs",
    "e2e": "playwright test",
    "e2e:kit": "playwright test e2e/realmorphism-kit-scroll.spec.ts e2e/realmorphism-kit-rolling-picker.spec.ts e2e/glyph-oneline-art-roller.spec.ts",
    "e2e:layout": "playwright test e2e/cyberdeck.layout.spec.ts",
    "e2e:headed": "playwright test --headed",
    "e2e:report": "playwright show-report",
    "test:predeploy:layout": "pnpm exec tsc --noEmit && pnpm build && playwright test e2e/cyberdeck.layout.spec.ts",
    "test:predeploy:kit": "pnpm exec tsc --noEmit && playwright test e2e/realmorphism-kit-scroll.spec.ts e2e/realmorphism-kit-rolling-picker.spec.ts e2e/glyph-oneline-art-roller.spec.ts",
    "test:predeploy": "pnpm exec tsc --noEmit && pnpm probe:muthur-observation && pnpm build && playwright test",
    "voice:cursor:enable-mechanicus": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/enable-mechanicus-cursor-voice.ps1",
    "voice:cursor:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/stop-mechanicus-cursor-voice.ps1",
    "voice:cursor:debug": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/debug-mechanicus-cursor-voice.ps1",
    "voice:cursor:read-last-response": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$env:SAMUS_MANUS_ROOT='C:\\dev\\samus-manus'; $env:CURSOR_HOOK_MECHANICUS_EXTRACT='full'; $env:CURSOR_HOOK_MECHANICUS_LAST_SENTENCE='1'; $env:CURSOR_HOOK_MECHANICUS_WAIT='1'; $j = Join-Path (Get-Location) '.cursor/hooks/sample-after-agent.json'; if (-not (Test-Path $j)) { Write-Error 'Missing .cursor/hooks/sample-after-agent.json'; exit 1 }; Get-Content -Raw $j | powershell -NoProfile -ExecutionPolicy Bypass -File (Join-Path (Get-Location) '.cursor/hooks/run-speak-last-mechanicus.ps1')\"",
    "voice:cursor:read-last-response:dry": "python .cursor/hooks/speak_last_sentence_mechanicus.py --dry-run",
    "hook:test-mechanicus-last": "python .cursor/hooks/speak_last_sentence_mechanicus.py --self-test",
    "hook:dry-mechanicus-last": "python .cursor/hooks/speak_last_sentence_mechanicus.py --dry-run",
    "hook:smoke-mechanicus-voice": "pnpm run voice:cursor:read-last-response"
  },
