{
  "name": "echo-mirage-cyberdeck",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "main": "electron/main.js",
  "scripts": {
    "dev": "node scripts/next-dev.mjs",
    "dev:stop": "node scripts/dev-stop.mjs",
    "dev:reset": "powershell -ExecutionPolicy Bypass -File scripts/dev-reset.ps1",
    "dev:turbo": "node scripts/next-dev.mjs --turbopack",
    "build": "next build --webpack",
    "start": "next start -p 3050",
    "preview": "next build && next start -p 3050",
    "voice:restore": "node scripts/restore-muthur-voice.mjs",
    "voice:save": "tsx scripts/save-muthur-voice.ts",
    "electron:dev": "node scripts/dev-stop.mjs && concurrently -k \"node scripts/next-dev.mjs --webpack --auto-port\" \"node scripts/wait-dev-server.mjs && node scripts/warm-cyberdeck.mjs && electron .\"",
    "electron:dev:fixed": "concurrently -k \"node scripts/next-dev.mjs --webpack\" \"wait-on -t 300000 -i 2000 -d 15000 http-get://127.0.0.1:3051/health && node scripts/warm-cyberdeck.mjs && electron .\"",
    "electron:dev:auto": "pnpm electron:dev",
    "electron:prod": "next build && concurrently \"next start -p 3050\" \"electron .\"",
    "lint": "eslint .",
    "lint:fix": "eslint --ext .js,.jsx,.ts,.tsx . --fix",
    "lint:watch": "eslint --ext .js,.jsx,.ts,.tsx . --fix --watch",
    "lmstudio:probe": "node scripts/lmstudio-probe.js",
    "registry:build": "node ../realmorphism/scripts/build-registry.mjs --sync-echo",
    "fonts:sync": "node scripts/sync-figlet-fonts.mjs",
    "fonts:sync-pyfiglet": "node scripts/sync-pyfiglet-fonts.mjs",
    "fonts:sync-all": "node scripts/sync-figlet-fonts.mjs && node scripts/sync-pyfiglet-fonts.mjs && node scripts/write-figlet-font-manifest.mjs",
    "fonts:manifest": "node scripts/write-figlet-font-manifest.mjs",
    "oneline-art:sync": "node scripts/sync-oneline-art-gist.mjs",
    "oneline-art:sync-asky": "node scripts/sync-asky-oneline-art.mjs",
    "oneline-art:sync-kulaone": "node scripts/sync-kulaone-oneline-art.mjs",
    "oneline-art:sync-all": "node scripts/sync-oneline-art-gist.mjs && node scripts/sync-asky-oneline-art.mjs && node scripts/sync-kulaone-oneline-art.mjs",
    "probe:memory-cards": "tsx scripts/probe-memory-card-registry.ts && tsx scripts/probe-memory-card-parser-regression.ts",
    "probe:muthur-observation": "tsx scripts/probe-muthur-observation.ts",
    "probe:muthur-phase-a": "tsx scripts/probe-muthur-phase-a-coder.ts",
    "probe:muthur-phase-b": "tsx scripts/probe-muthur-phase-b-verify.ts",
    "probe:muthur-phase-c": "tsx scripts/probe-muthur-phase-c-uplink-mode.ts",
    "probe:muthur-operator-disk-save": "tsx scripts/probe-muthur-operator-disk-save.ts",
    "probe:muthur-persistent-runtime": "tsx scripts/probe-muthur-persistent-runtime.ts",
    "probe:muthur-atlas-memory": "tsx scripts/probe-muthur-atlas-memory.ts",
    "probe:muthur-phases": "pnpm probe:muthur-phase-a && pnpm probe:muthur-phase-b && pnpm probe:muthur-phase-c && pnpm probe:muthur-operator-disk-save && pnpm probe:muthur-persistent-runtime && pnpm probe:muthur-atlas-memory",
    "probe:muthur-open-operator": "tsx scripts/probe-muthur-open-operator.ts",
    "probe:powerfist-muthur-tools": "tsx scripts/probe-powerfist-muthur-tools.ts",
    "probe:muthur-dsml": "tsx scripts/probe-dsml-parse.ts",
    "probe:operator-file-surface": "tsx scripts/probe-operator-file-surface.ts",
    "probe:resolve-convert-document-path": "tsx scripts/probe-resolve-convert-document-path.ts",
    "puppeteer:install": "node scripts/install-puppeteer-chrome.mjs",
    "e2e": "playwright test",
    "e2e:kit": "playwright test e2e/realmorphism-kit-scroll.spec.ts e2e/realmorphism-kit-rolling-picker.spec.ts e2e/glyph-oneline-art-roller.spec.ts",
    "e2e:layout": "playwright test e2e/cyberdeck.layout.spec.ts",
    "e2e:headed": "playwright test --headed",
    "e2e:report": "playwright show-report",
    "test:predeploy:layout": "pnpm exec tsc --noEmit && pnpm build && playwright test e2e/cyberdeck.layout.spec.ts",
    "test:predeploy:kit": "pnpm exec tsc --noEmit && playwright test e2e/realmorphism-kit-scroll.spec.ts e2e/realmorphism-kit-rolling-picker.spec.ts e2e/glyph-oneline-art-roller.spec.ts",
    "test:predeploy": "pnpm exec tsc --noEmit && pnpm probe:muthur-observation && pnpm build && playwright test",
    "voice:cursor:read-last-response": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$env:CURSOR_HOOK_MECHANICUS_EXTRACT='full'; $j = Join-Path (Get-Location) '.cursor/hooks/sample-after-agent.json'; if (-not (Test-Path $j)) { Write-Error 'Missing .cursor/hooks/sample-after-agent.json'; exit 1 }; Get-Content -Raw $j | python -u (Join-Path (Get-Location) '.cursor/hooks/speak_last_sentence_mechanicus.py')\"",
    "voice:cursor:read-last-response:dry": "python .cursor/hooks/speak_last_sentence_mechanicus.py --dry-run"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.3.24",
    "@eigenpal/docx-editor-react": "^1.3.1",
    "@lexical/react": "^0.39.0",
    "@lexical/rich-text": "^0.39.0",
    "@mariozechner/mini-lit": "^0.2.1",
    "@mariozechner/pi-agent-core": "^0.72.1",
    "@mariozechner/pi-ai": "^0.72.1",
    "@mariozechner/pi-web-ui": "^0.72.1",
    "@mediapipe/tasks-vision": "^0.10.34",
    "@mohtasham/md-to-docx": "^2.12.0",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "@tanstack/react-query": "^5.100.14",
    "@wikimedia/codex-icons": "^2.5.1",
    "ai": "^6.0.141",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cropperjs": "^2.1.0",
    "docx-preview": "^0.3.7",
    "electron": "41.3.0",
    "embla-carousel": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "figlet": "^1.11.0",
    "geist": "^1.7.0",
    "google-photos-album-image-url-fetch": "3.2.0",
    "idb-keyval": "^6.2.2",
    "immer": "^10.2.0",
    "jszip": "^3.10.1",
    "just-bash": "^2.14.4",
    "langchain": "^1.2.37",
    "lexical": "^0.39.0",
    "lit": "^3.3.2",
    "lucide-react": "^0.511.0",
    "md-to-pdf": "^5.2.5",
    "monaco-editor": "^0.55.1",
    "motion": "^12.38.0",
    "nanoid": "^5.1.7",
    "next": "16.1.5",
    "next-themes": "^0.4.6",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.0.227",
    "pi-free": "^2.0.7",
    "puppeteer": "^24.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.6.0",
    "react-json-view": "^1.21.3",
    "react-resizable-panels": "^4.7.6",
    "react-type-animation": "^3.2.0",
    "realmorphism": "github:loteknowledG/realmorphism#master",
    "sonner": "^2.0.7",
    "sql.js": "^1.14.1",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^2.6.1",
    "tailwindcss-animate": "^1.0.7",
    "use-stick-to-bottom": "^1.1.3",
    "zod": "^3.25.76",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@effect/language-service": "^0.84.3",
    "@next/eslint-plugin-next": "^16.2.1",
    "@playwright/test": "^1.58.2",
    "@types/figlet": "^1.7.0",
    "@types/node": "^20.19.37",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/sql.js": "^1.4.11",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "concurrently": "^9.1.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "14.2.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "postcss": "^8.5.8",
    "prettier": "^2.8.8",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "wait-on": "^7.2.0"
  },
  "pnpm": {
    "overrides": {
      "pdfjs-dist": "$pdfjs-dist"
    },
    "onlyBuiltDependencies": [
      "@google/genai",
      "@mongodb-js/zstd",
      "electron"
    ]
  }
}
