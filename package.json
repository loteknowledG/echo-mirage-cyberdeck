{
  "name": "echo-mirage-cyberdeck",
  "version": "0.1.4",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "main": "electron/main.js",
  "scripts": {
    "dev": "node scripts/next-dev.mjs",
    "dev:stop": "node scripts/dev-stop.mjs",
    "dev:reset": "powershell -ExecutionPolicy Bypass -File scripts/dev-reset.ps1",
    "dev:turbo": "node scripts/next-dev.mjs --turbopack",
    "build": "node scripts/clean-windows-build-blockers.mjs && node scripts/copy-figlet-npm-fonts.mjs && node scripts/write-figlet-font-manifest.mjs && next build --webpack",
    "fonts:normalize": "node scripts/run-python.mjs scripts/normalize-commodore-figlet-fonts.py",
    "start": "next start -p 3050",
    "preview": "next build && next start -p 3050",
    "voice:restore": "node scripts/restore-muthur-voice.mjs",
    "voice:save": "tsx scripts/save-muthur-voice.ts",
    "electron:dev": "node scripts/dev-stop.mjs && concurrently -k \"node scripts/next-dev.mjs --webpack --auto-port\" \"node scripts/warm-cyberdeck.mjs && electron .\"",
    "electron:dev:fixed": "concurrently -k \"node scripts/next-dev.mjs --webpack\" \"wait-on -t 300000 -i 2000 -d 15000 http-get://127.0.0.1:3051/health && node scripts/warm-cyberdeck.mjs && electron .\"",
    "electron:dev:auto": "pnpm electron:dev",
    "electron:prod": "next build && concurrently \"next start -p 3050\" \"electron .\"",
    "electron:prepare": "node scripts/prepare-electron-standalone.mjs",
    "electron:pack": "node scripts/prepare-electron-standalone.mjs && electron-builder --win",
    "electron:pack:dir": "node scripts/prepare-electron-standalone.mjs && electron-builder --win --dir",
    "electron:pack:mac": "node scripts/prepare-electron-standalone.mjs && electron-builder --mac",
    "electron:pack:mac:dir": "node scripts/prepare-electron-standalone.mjs && electron-builder --mac --dir",
    "satellite:dev": "pnpm --dir apps/echo-satellite-electron dev",
    "satellite:build": "pnpm --dir apps/echo-satellite-electron build",
    "lint": "eslint .",
    "lint:fix": "eslint --ext .js,.jsx,.ts,.tsx . --fix",
    "lint:watch": "eslint --ext .js,.jsx,.ts,.tsx . --fix --watch",
    "lmstudio:probe": "node scripts/lmstudio-probe.js",
    "registry:build": "node ../realmorphism/scripts/build-registry.mjs --sync-echo",
    "fonts:sync": "node scripts/sync-figlet-fonts.mjs",
    "fonts:sync-pyfiglet": "node scripts/sync-pyfiglet-fonts.mjs",
    "fonts:sync-all": "node scripts/sync-figlet-fonts.mjs && node scripts/sync-pyfiglet-fonts.mjs && node scripts/write-figlet-font-manifest.mjs",
    "fonts:manifest": "node scripts/write-figlet-font-manifest.mjs",
    "oneline-art:sync": "node scripts/sync-oneline-art-gist.mjs",
    "oneline-art:sync-asky": "node scripts/sync-asky-oneline-art.mjs",
    "oneline-art:sync-kulaone": "node scripts/sync-kulaone-oneline-art.mjs",
    "oneline-art:sync-all": "node scripts/sync-oneline-art-gist.mjs && node scripts/sync-asky-oneline-art.mjs && node scripts/sync-kulaone-oneline-art.mjs",
    "probe:memory-cards": "tsx scripts/probe-memory-card-registry.ts && tsx scripts/probe-memory-card-parser-regression.ts",
    "probe:muthur-observation": "tsx scripts/probe-muthur-observation.ts",
    "probe:muthur-phase-a": "tsx scripts/probe-muthur-phase-a-coder.ts",
    "probe:muthur-phase-b": "tsx scripts/probe-muthur-phase-b-verify.ts",
    "probe:muthur-phase-c": "tsx scripts/probe-muthur-posture.ts",
    "probe:muthur-commander-delegation": "tsx scripts/probe-muthur-commander-delegation.ts",
    "probe:muthur-commander-posture": "tsx scripts/probe-muthur-commander-posture.ts",
    "probe:ambient-twinkle": "tsx scripts/probe-ambient-twinkle.ts",
    "probe:pi-computer-use": "tsx scripts/probe-pi-computer-use.ts",
    "probe:calyx-smoke": "tsx scripts/probe-calyx-smoke.ts",
    "calyx:ingest-echo-mirage": "tsx scripts/ingest-echo-mirage-calyx.ts",
    "probe:pi-windows-use": "node scripts/pi/run-windows-use-probe.mjs",
    "probe:muthur-control-lease": "tsx scripts/probe-muthur-control-lease.ts",
    "probe:pi-control-lease-boundary": "tsx scripts/probe-pi-control-lease-boundary.ts",
    "probe:muthur-cognition": "tsx scripts/probe-muthur-cognition.ts",
