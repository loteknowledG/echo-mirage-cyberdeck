{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "realmorphism-site",
  "type": "registry:block",
  "title": "Realmorphism Registry Site",
  "description": "A portable showroom page for the Realmorphism shadcn registry.",
  "author": "LT Lo TeknowledG",
  "registryDependencies": [
    "http://localhost:3050/registry/realmorphism-base.json"
  ],
  "files": [
    {
      "type": "registry:page",
      "path": "app/registry/page.tsx",
      "target": "app/registry/page.tsx",
      "content": "import type { Metadata } from 'next';\n\nconst installCommands = [\n  { label: 'Theme', command: 'npx shadcn@latest add http://localhost:3050/registry/realmorphism.json' },\n  { label: 'Base Kit', command: 'npx shadcn@latest add http://localhost:3050/registry/realmorphism-base.json' },\n  { label: 'Showroom Site', command: 'npx shadcn@latest add http://localhost:3050/registry/realmorphism-site.json' },\n];\n\nconst swatches = [\n  ['Host', '#060708'],\n  ['Raised', '#0e1011'],\n  ['Face', '#171c19'],\n  ['Wall', '#2a6b56'],\n  ['Hover', '#3a9174'],\n  ['Amber', '#8a6530'],\n  ['Signal', '#7dffb4'],\n  ['Ink', '#e8efeb'],\n];\n\nexport const metadata: Metadata = {\n  title: 'Realmorphism Registry',\n  description: 'shadcn registry showroom for the Realmorphism theme.',\n};\n\nexport default function RegistryPage() {\n  return (\n    <main data-deck-mode=\"realmorphism\" className=\"h-screen overflow-y-auto bg-[#060708] px-4 py-6 text-[#e8efeb] sm:px-6 lg:px-10\">\n      <div data-morphism=\"realmorphism\" className=\"mx-auto flex max-w-6xl flex-col gap-8\">\n        <header className=\"grid gap-6 border-b border-[#2a3530] pb-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-end\">\n          <div className=\"space-y-5\">\n            <div className=\"inline-flex border border-[#2a3530] bg-[#0e1011] px-3 py-1 font-mono text-xs uppercase tracking-[0.18em] text-[#7dffb4]\">Realmorphism Registry</div>\n            <div className=\"space-y-3\">\n              <h1 className=\"max-w-3xl text-4xl font-semibold tracking-normal text-[#e8efeb] sm:text-6xl\">Realmorphism</h1>\n              <p className=\"max-w-2xl text-base leading-7 text-[#9eada7]\">A blocky tactile shadcn theme for operational interfaces. The colors define the planes; the motion tells the operator an action is available.</p>\n            </div>\n          </div>\n          <div className=\"grid gap-3 rounded-[var(--realmorphism-radius)] border border-[#2a3530] bg-[#0e1011] p-4 shadow-[var(--realmorphism-shadow-rest)]\">\n            <div className=\"font-mono text-xs uppercase tracking-[0.16em] text-[#9eada7]\">Install</div>\n            {installCommands.map((item) => (\n              <div key={item.label} className=\"space-y-1\">\n                <div className=\"font-mono text-xs text-[#7dffb4]\">{item.label}</div>\n                <pre className=\"overflow-x-auto rounded-[var(--realmorphism-radius-sm)] border border-[#2a3530] bg-[#060708] p-3 text-xs text-[#e8efeb]\">{item.command}</pre>\n              </div>\n            ))}\n          </div>\n        </header>\n        <section className=\"grid gap-4 md:grid-cols-4\">\n          {swatches.map(([label, color]) => (\n            <div key={label} className=\"rounded-[var(--realmorphism-radius)] border border-[#2a3530] bg-[#0e1011] p-3\">\n              <div className=\"mb-3 h-16 border border-[#2a3530]\" style={{ background: color }} />\n              <div className=\"font-mono text-sm text-[#e8efeb]\">{label}</div>\n              <div className=\"font-mono text-xs text-[#6f7a75]\">{color}</div>\n            </div>\n          ))}\n        </section>\n        <section className=\"rounded-[var(--realmorphism-radius)] border border-[#2a3530] bg-[#0e1011] p-5 shadow-[var(--realmorphism-shadow-rest)]\">\n          <h2 className=\"mb-4 text-xl font-semibold\">Action Surface</h2>\n          <div className=\"flex flex-wrap gap-4\">\n            <button className=\"realmorphism-control border px-5 py-3 font-mono text-sm\">Commit</button>\n            <button type=\"button\" aria-pressed className=\"realmorphism-control border px-5 py-3 font-mono text-sm\">Selected</button>\n            <button className=\"realmorphism-control is-amber border px-5 py-3 font-mono text-sm\">Caution</button>\n          </div>\n        </section>\n      </div>\n    </main>\n  );\n}\n"
    }
  ]
}
